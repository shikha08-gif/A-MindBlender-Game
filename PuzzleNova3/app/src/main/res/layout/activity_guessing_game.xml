<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1E1B4B"
    android:padding="24dp"
    tools:context=".GuessingGameActivity">

    <!-- Main Game Area (Hidden at start) -->
    <RelativeLayout
        android:id="@+id/game_layout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone">

        <!-- Title -->
        <TextView
            android:id="@+id/title_text_view"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentTop="true"
            android:layout_centerHorizontal="true"
            android:text="Guess the Number"
            android:textColor="#00ffff"
            android:textSize="34sp"
            android:textStyle="bold" />

        <!-- Instructions (will be set by code) -->
        <TextView
            android:id="@+id/instructions_text_view"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@id/title_text_view"
            android:layout_marginTop="16dp"
            android:gravity="center"
            android:text="Guess a number between 1 and 100"
            android:textColor="#88aaff"
            android:textSize="18sp" />

        <!-- Guesses Left -->
        <TextView
            android:id="@+id/guesses_left_text_view"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@id/instructions_text_view"
            android:layout_marginTop="24dp"
            android:gravity="center"
            android:text="Guesses Left: 10"
            android:textColor="#00ffff"
            android:textSize="20sp"
            android:textStyle="bold" />

        <!-- Main Feedback Text -->
        <TextView
            android:id="@+id/feedback_text_view"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@id/guesses_left_text_view"
            android:layout_marginTop="32dp"
            android:gravity="center"
            android:minHeight="48dp"
            android:text="Enter your guess!"
            android:textColor="#00ffff"
            android:textSize="22sp"
            android:textStyle="bold" />

        <!-- Number Input -->
        <EditText
            android:id="@+id/guess_input_edit_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@id/feedback_text_view"
            android:layout_marginTop="24dp"
            android:backgroundTint="#00ffff"
            android:gravity="center"
            android:hint="Your Guess"
            android:inputType="number"
            android:maxLength="3"
            android:textColor="#ffffff"
            android:textColorHint="#88aaff"
            android:textSize="28sp" />

        <!-- Guess Button -->
        <Button
            android:id="@+id/guess_button"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@id/guess_input_edit_text"
            android:layout_marginTop="24dp"
            android:backgroundTint="#003366"
            android:elevation="4dp"
            android:outlineAmbientShadowColor="#00ffff"
            android:outlineSpotShadowColor="#00ffff"
            android:paddingVertical="16dp"
            android:text="GUESS"
            android:textColor="#00ffff"
            android:textSize="20sp"
            android:textStyle="bold" />

        <!-- In-Game Button Bar -->
        <LinearLayout
            android:id="@+id/in_game_button_bar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_alignParentBottom="true"
            android:orientation="horizontal">

            <Button
                android:id="@+id/reset_button"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                android:layout_weight="1"
                android:backgroundTint="#003366"
                android:elevation="4dp"
                android:outlineAmbientShadowColor="#00ffff"
                android:outlineSpotShadowColor="#00ffff"
                android:paddingVertical="16dp"
                android:text="Reset"
                android:textColor="#00ffff"
                android:textStyle="bold" />

            <Button
                android:id="@+id/new_game_button"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:backgroundTint="#003366"
                android:elevation="4dp"
                android:outlineAmbientShadowColor="#00ffff"
                android:outlineSpotShadowColor="#00ffff"
                android:paddingVertical="16dp"
                android:text="New Game"
                android:textColor="#00ffff"
                android:textStyle="bold" />
        </LinearLayout>

    </RelativeLayout>

    <!-- START BUTTON has been removed -->

</RelativeLayout>

