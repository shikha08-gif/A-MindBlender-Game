<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1E1B4B"
    tools:context=".GameHubActivity">


    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp"
            android:gravity="center_horizontal">


            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginTop="32dp"
                android:layout_marginBottom="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🧩"
                    android:textSize="24sp"
                    android:textColor="#9333ea" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=" PUZZLENOVA"
                    android:textSize="28sp"
                    android:textStyle="bold"
                    android:textColor="@android:color/white"/>
            </LinearLayout>


            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="COSMIC GAMING NEXUS - EXPLORE THE UNIVERSE OF MIND GAMES"
                android:textSize="14sp"
                android:textColor="#a78bfa"
                android:letterSpacing="0.1"
                android:layout_marginBottom="32dp"/>


            <androidx.gridlayout.widget.GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                app:columnCount="2"
                app:rowCount="3">


                <androidx.cardview.widget.CardView
                    android:id="@+id/card_2048"
                    style="@style/GameHubCardStyle"
                    app:layout_columnWeight="1"
                    app:layout_rowWeight="1">
                    <LinearLayout style="@style/GameCardContent">
                        <TextView style="@style/GameCardIcon" android:text="🎯" />
                        <TextView style="@style/GameCardTitle" android:text="2048" />
                        <TextView style="@style/GameCardDescription" android:text="Combine tiles to reach 2048. Swipe to move all tiles in one direction and create the ultimate number!" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>


                <androidx.cardview.widget.CardView
                    android:id="@+id/card_sudoku"
                    style="@style/GameHubCardStyle"
                    app:layout_columnWeight="1"
                    app:layout_rowWeight="1">
                    <LinearLayout style="@style/GameCardContent">
                        <TextView style="@style/GameCardIcon" android:text="🔢" />
                        <TextView style="@style/GameCardTitle" android:text="SUDOKU" />
                        <TextView style="@style/GameCardDescription" android:text="Fill the 9x9 grid so each row, column, and 3x3 box contains digits 1-9. Logic meets perfection!" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>


                <androidx.cardview.widget.CardView
                    android:id="@+id/card_maths_quiz"
                    style="@style/GameHubCardStyle"
                    app:layout_columnWeight="1"
                    app:layout_rowWeight="1">
                    <LinearLayout style="@style/GameCardContent">
                        <TextView style="@style/GameCardIcon" android:text="🧮" />
                        <TextView style="@style/GameCardTitle" android:text="MATHS QUIZ" />
                        <TextView style="@style/GameCardDescription" android:text="Test your mental math skills with quick arithmetic challenges! Speed and accuracy are key." />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>


                <androidx.cardview.widget.CardView
                    android:id="@+id/card_sliding_puzzle"
                    style="@style/GameHubCardStyle"
                    app:layout_columnWeight="1"
                    app:layout_rowWeight="1">
                    <LinearLayout style="@style/GameCardContent">
                        <TextView style="@style/GameCardIcon" android:text="🚾" />
                        <TextView style="@style/GameCardTitle" android:text="WORD CROSS" />
                        <TextView style="@style/GameCardDescription" android:text="Word Cross is a IG game which i confsume your brain and IG." />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>


                <androidx.cardview.widget.CardView
                    android:id="@+id/card_number_guessing"
                    style="@style/GameHubCardStyle"
                    app:layout_columnWeight="1"
                    app:layout_rowWeight="1">
                    <LinearLayout style="@style/GameCardContent">
                        <TextView style="@style/GameCardIcon" android:text="🎲" />
                        <TextView style="@style/GameCardTitle" android:text="NUMBER GUESSING" />
                        <TextView style="@style/GameCardDescription" android:text="Guess the secret number between 1 and 100. How many tries will it take? Test your intuition!" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>


                <androidx.cardview.widget.CardView
                    android:id="@+id/card_memory_match"
                    style="@style/GameHubCardStyle"
                    app:layout_columnWeight="1"
                    app:layout_rowWeight="1">
                    <LinearLayout style="@style/GameCardContent">
                        <TextView style="@style/GameCardIcon" android:text="🧠" />
                        <TextView style="@style/GameCardTitle" android:text="MEMORY MATCH" />
                        <TextView style="@style/GameCardDescription" android:text="Find matching pairs by remembering card positions. Match them all and train your memory!" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>


                <androidx.cardview.widget.CardView
                    xmlns:android="http://schemas.android.com/apk/res/android"
                    xmlns:app="http://schemas.android.com/apk/res-auto"
                    android:id="@+id/card_sliding_tiles"
                    style="@style/GameHubCardStyle"
                    app:layout_columnWeight="1"
                    app:layout_rowWeight="1">

                    <LinearLayout
                        style="@style/GameCardContent"
                        android:orientation="vertical"
                        android:gravity="center_horizontal"
                        android:padding="16dp">

                        <ImageView
                            android:id="@+id/game_slide_icon"
                            android:layout_width="64dp"
                            android:layout_height="64dp"
                            android:layout_marginBottom="8dp"
                            android:src="@drawable/ic_slide_tiles"
                            android:contentDescription="Sliding Tiles Icon" />

                        <!-- Title (Neon Color) -->
                        <TextView
                            style="@style/GameCardTitle"
                            android:text="SLIDING TILES"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content" />

                        <!-- Description (Neon Color) -->
                        <TextView
                            style="@style/GameCardDescription"
                            android:text="Challenge your brain with Sliding Tiles — the timeless puzzle that keeps you thinking!"
                            android:gravity="center"
                            android:textSize="14sp"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content" />

                    </LinearLayout>
                </androidx.cardview.widget.CardView>


                <androidx.cardview.widget.CardView
                    xmlns:android="http://schemas.android.com/apk/res/android"
                    xmlns:app="http://schemas.android.com/apk/res-auto"
                    android:id="@+id/card_block_fill"
                    style="@style/GameHubCardStyle"
                    app:layout_columnWeight="1"
                    app:layout_rowWeight="1">


                    <LinearLayout
                        style="@style/GameCardContent"
                        android:orientation="vertical"
                        android:gravity="center_horizontal"
                        android:padding="16dp">


                        <ImageView
                            android:id="@+id/game_block_icon"
                            android:layout_width="64dp"
                            android:layout_height="64dp"
                            android:layout_marginBottom="8dp"
                            android:src="@drawable/ic_block_fill"
                            android:contentDescription="Block Fill Icon" />

                        <TextView
                            style="@style/GameCardTitle"
                            android:text="BLOCK FILL"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content" />

                        <TextView
                            style="@style/GameCardDescription"
                            android:text="Draw a path from start to finish, filling every single block on the board!"
                            android:gravity="center"
                            android:textSize="14sp"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content" />

                    </LinearLayout>
                </androidx.cardview.widget.CardView>

            </androidx.gridlayout.widget.GridLayout>

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
