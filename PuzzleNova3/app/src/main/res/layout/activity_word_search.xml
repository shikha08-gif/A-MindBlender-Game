<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1E1B4B"
    android:padding="16dp"
    tools:context=".WordSearchActivity">

    <TextView
        android:id="@+id/title_text_view"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentTop="true"
        android:layout_centerHorizontal="true"
        android:layout_marginBottom="16dp"
        android:text="Word Search"
        android:textColor="#00ffff"
        android:textSize="34sp"
        android:textStyle="bold" />

    <!-- Word List Box -->
    <androidx.cardview.widget.CardView
        android:id="@+id/word_list_box"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/title_text_view"
        app:cardBackgroundColor="#4C1D95"
        app:cardCornerRadius="8dp"
        app:cardElevation="4dp"
        android:layout_marginBottom="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp">

            <TextView
                android:id="@+id/score_text_view"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="Found: 0 / 6"
                android:textColor="#00ffff"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/words_list_text_view"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:layout_marginTop="8dp"
                tools:text="WORD1  WORD2  WORD3"
                android:textColor="#88aaff"
                android:textSize="16sp" />

        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- Reset and New Game Buttons -->
    <LinearLayout
        android:id="@+id/button_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:orientation="horizontal">

        <Button
            android:id="@+id/reset_button"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Reset"
            android:backgroundTint="#003366"
            android:textColor="#00ffff"
            android:layout_marginEnd="8dp"
            android:paddingVertical="12dp"
            android:textSize="16sp"/>

        <Button
            android:id="@+id/new_game_button"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="New Game"
            android:backgroundTint="#003366"
            android:textColor="#00ffff"
            android:layout_marginStart="8dp"
            android:paddingVertical="12dp"
            android:textSize="16sp"/>
    </LinearLayout>

    <!-- Game Grid Box -->
    <androidx.cardview.widget.CardView
        android:id="@+id/game_grid_box"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/word_list_box"
        android:layout_above="@id/button_bar"
        android:layout_marginBottom="16dp"
        app:cardBackgroundColor="#00000000"
        app:cardElevation="0dp">

        <!-- This is your custom game view -->
        <com.example.puzzlenova.WordSearchView
            android:id="@+id/word_search_view"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center" />

    </androidx.cardview.widget.CardView>

</RelativeLayout>

