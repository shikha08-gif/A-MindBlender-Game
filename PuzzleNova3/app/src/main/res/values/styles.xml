<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Base style for the game card containers -->
    <style name="GameHubCardStyle" parent="CardView.Light">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="cardBackgroundColor">#312E81</item> <!-- Dark Slate Blue -->
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">8dp</item>
        <item name="cardUseCompatPadding">true</item>
        <item name="cardPreventCornerOverlap">false</item>
    </style>

    <!-- Style for the content inside the card -->
    <style name="GameCardContent">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:orientation">vertical</item>
        <item name="android:gravity">center_horizontal</item>
        <item name="android:padding">16dp</item>
    </style>

    <!-- Style for the game icon (large emoji) -->
    <style name="GameCardIcon">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textSize">48sp</item>
        <item name="android:layout_marginBottom">8dp</item>
    </style>

    <!-- Style for the game title -->
    <style name="GameCardTitle">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textSize">18sp</item>
        <item name="android:textColor">@android:color/white</item>
        <item name="android:textStyle">bold</item>
        <item name="android:layout_marginBottom">8dp</item>
    </style>

    <!-- Style for the game description -->
    <style name="GameCardDescription">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textSize">12sp</item>
        <item name="android:textColor">#E9D5FF</item>
        <item name="android:textAlignment">center</item>
        <item name="android:maxLines">4</item>
        <item name="android:minLines">3</item>
        <item name="android:ellipsize">end</item>
        <item name="android:layout_marginBottom">16dp</item>
    </style>

    <!-- Style for the Launch Game button -->
    <style name="GameCardButton" parent="Widget.AppCompat.Button.Colored">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">@android:color/white</item>
        <item name="android:background">@drawable/button_gradient_small</item>
        <item name="android:paddingStart">24dp</item>
        <item name="android:paddingEnd">24dp</item>
        <item name="android:paddingTop">12dp</item>
        <item name="android:paddingBottom">12dp</item>
    </style>

    <style name="SudokuNumberButton" parent="Widget.AppCompat.Button">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_columnWeight">1</item>
        <item name="android:layout_margin">4dp</item>
        <item name="android:backgroundTint">#4C1D95</item> <!-- Dark Purple Neon -->
        <item name="android:textColor">#00ffff</item> <!-- Neon Cyan -->
        <item name="android:textSize">18sp</item>
        <item name="android:textStyle">bold</item>
    </style>
</resources>
